# Copy this to `.env` and fill in. The actual .env is gitignored.
#
# TOOLBOX_TOKEN — reserved for the v2 bearer-token auth layer (not yet enforced
# by the gateway; the toolbox is LAN-trust today). Generate a random hex string
# now so it's ready when auth ships. Example:
#   TOOLBOX_TOKEN=$(openssl rand -hex 24)

TOOLBOX_TOKEN=replace-me-with-openssl-rand-hex-24
